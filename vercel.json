{
  "version": 2,
  "functions": {
    "api/admin-run-job.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/api/profiles/:domain",
      "destination": "/api/profile?domain=:domain"
    }
  ]
}
