<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 220 60" fill="none">
  <!-- Gear icon -->
  <g transform="translate(4, 4)">
    <!-- Gear body - blue -->
    <path d="
      M26 2
      l2.5 0 1 4.5
      a18 18 0 0 1 5.2 2.1l4.2-1.8 1.8 1.8-1.8 4.2
      a18 18 0 0 1 2.1 5.2l4.5 1 0 2.5-4.5 1
      a18 18 0 0 1-2.1 5.2l1.8 4.2-1.8 1.8-4.2-1.8
      a18 18 0 0 1-5.2 2.1l-1 4.5-2.5 0-1-4.5
      a18 18 0 0 1-5.2-2.1l-4.2 1.8-1.8-1.8 1.8-4.2
      a18 18 0 0 1-2.1-5.2l-4.5-1 0-2.5 4.5-1
      a18 18 0 0 1 2.1-5.2l-1.8-4.2 1.8-1.8 4.2 1.8
      a18 18 0 0 1 5.2-2.1z
    " fill="#4A8FD4"/>

    <!-- Yellow accent crescent at bottom -->
    <path d="M 6 34 a 21.5 21.5 0 0 0 40 0 z" fill="#F5C842" opacity="0.9"/>

    <!-- Inner circle background -->
    <circle cx="27.5" cy="27.5" r="14" fill="#2563a8"/>

    <!-- Brain / neural network nodes -->
    <!-- Central node -->
    <circle cx="27.5" cy="27" r="2.2" fill="white" opacity="0.95"/>
    <!-- Surrounding nodes -->
    <circle cx="27.5" cy="20" r="1.6" fill="white" opacity="0.85"/>
    <circle cx="34" cy="23.5" r="1.6" fill="white" opacity="0.85"/>
    <circle cx="34" cy="30.5" r="1.6" fill="white" opacity="0.85"/>
    <circle cx="27.5" cy="34" r="1.6" fill="white" opacity="0.85"/>
    <circle cx="21" cy="30.5" r="1.6" fill="white" opacity="0.85"/>
    <circle cx="21" cy="23.5" r="1.6" fill="white" opacity="0.85"/>
    <!-- Outer ring nodes -->
    <circle cx="27.5" cy="15" r="1.1" fill="white" opacity="0.6"/>
    <circle cx="37" cy="20" r="1.1" fill="white" opacity="0.6"/>
    <circle cx="37" cy="35" r="1.1" fill="white" opacity="0.6"/>
    <circle cx="27.5" cy="40" r="1.1" fill="white" opacity="0.6"/>
    <circle cx="18" cy="35" r="1.1" fill="white" opacity="0.6"/>
    <circle cx="18" cy="20" r="1.1" fill="white" opacity="0.6"/>

    <!-- Connection lines -->
    <line x1="27.5" y1="27" x2="27.5" y2="20" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <line x1="27.5" y1="27" x2="34" y2="23.5" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <line x1="27.5" y1="27" x2="34" y2="30.5" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <line x1="27.5" y1="27" x2="27.5" y2="34" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <line x1="27.5" y1="27" x2="21" y2="30.5" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <line x1="27.5" y1="27" x2="21" y2="23.5" stroke="white" stroke-width="0.7" opacity="0.5"/>
    <!-- Outer connections -->
    <line x1="27.5" y1="20" x2="27.5" y2="15" stroke="white" stroke-width="0.5" opacity="0.35"/>
    <line x1="34" y1="23.5" x2="37" y2="20" stroke="white" stroke-width="0.5" opacity="0.35"/>
    <line x1="34" y1="30.5" x2="37" y2="35" stroke="white" stroke-width="0.5" opacity="0.35"/>
    <line x1="27.5" y1="34" x2="27.5" y2="40" stroke="white" stroke-width="0.5" opacity="0.35"/>
    <line x1="21" y1="30.5" x2="18" y2="35" stroke="white" stroke-width="0.5" opacity="0.35"/>
    <line x1="21" y1="23.5" x2="18" y2="20" stroke="white" stroke-width="0.5" opacity="0.35"/>
  </g>

  <!-- "OpsMx" wordmark -->
  <text x="70" y="38" font-family="Inter, -apple-system, system-ui, sans-serif" font-size="26" font-weight="700" fill="white" letter-spacing="-0.5">OpsMx</text>
</svg>
